%% bitcoin-austria.sty
%% Bitcoin Austria Beamer style package (2026 brand kit).
%%
%% Implements the Bitcoin Austria brand:
%%   - Palette: red #E3000F, black #222222, light grey #ECECEC, white.
%%   - Typeface: Blinker (SIL OFL 1.1), shipped in fonts/, loaded via fontspec.
%%   - Dark logomark top-left, running short-title centre, frame number top-right.
%%   - Bold dark headlines with a short red accent rule.
%%
%% Requires: XeLaTeX (fontspec). LaTeX kernel 2020-10 or newer (for
%% \CurrentFilePath); any current TeX Live is fine.
%%
%% Reuse: this package is meant to be consumed as a git submodule. It locates
%% its own fonts/ and assets/ from the directory it was loaded from, so it works
%% regardless of where the submodule is mounted, as long as you load it by
%% (relative) path:
%%
%%   \usepackage{theme/bitcoin-austria}   % theme/ = the submodule directory
%%
%% If auto-detection ever fails, set the directory explicitly before loading:
%%   \def\bitcoinaustriaroot{theme/}      % note the trailing slash
%%
%% License: package code Apache-2.0; Blinker font under SIL OFL 1.1 (see fonts/).

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bitcoin-austria}[2026/06/26 v0.1 Bitcoin Austria Beamer style]

%% --- Required packages -------------------------------------------------------
\RequirePackage{fontspec}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\RequirePackage{booktabs}
\RequirePackage{etoolbox}   % robust \notblank for optional macro content
\RequirePackage{eso-pic}    % \AddToShipoutPictureFG for corner overlays
\RequirePackage{keyval}     % key=value options for \cornerimage (also via graphicx)
\RequirePackage[protrusion=true,expansion=false]{microtype}
\usetikzlibrary{calc}

%% --- Package options ---------------------------------------------------------
% [white] (alias [whitebg]): use a WHITE canvas for standard content slides
% instead of the default light-grey brand canvas — a fallback for projector or
% print contrast issues. [grey]/[gray] selects the (default) brand canvas
% explicitly. Dark theme slides (\fillerslide, full-bleed captions) are
% unaffected either way. Load like: \usepackage[white]{theme/bitcoin-austria}.
\newif\ifba@whitebg
\DeclareOption{white}{\ba@whitebgtrue}
\DeclareOption{whitebg}{\ba@whitebgtrue}
\DeclareOption{grey}{\ba@whitebgfalse}
\DeclareOption{gray}{\ba@whitebgfalse}
\DeclareOption*{\PackageWarning{bitcoin-austria}{Unknown option '\CurrentOption' ignored}}
\ProcessOptions\relax

% Locate THIS package's directory so fonts/ and assets/ resolve no matter where
% the submodule is mounted. \CurrentFilePath is the directory we were loaded
% from (e.g. "theme"); we append a slash. A consumer may override by defining
% \bitcoinaustriaroot (with trailing slash) before \usepackage.
\providecommand\CurrentFilePath{}        % guard for pre-2020 kernels
\edef\ba@root{\CurrentFilePath}
\ifx\ba@root\@empty\else\edef\ba@root{\ba@root/}\fi
\@ifundefined{bitcoinaustriaroot}{}{\edef\ba@root{\bitcoinaustriaroot}}

% Let \includegraphics find the bundled logos and the consumer's own images.
\graphicspath{{\ba@root}{\ba@root assets/}{pix/}{assets/}}

%% --- Brand colours -----------------------------------------------------------
\definecolor{baRed}{HTML}{E3000F}
\definecolor{baBlack}{HTML}{222222}
\definecolor{baGrey}{HTML}{ECECEC}
\definecolor{baWhite}{HTML}{FFFFFF}

% Standard-slide canvas: the light-grey brand colour by default; the [white]
% package option switches it to white. Everything else references baCanvas.
\colorlet{baCanvas}{baGrey}
\ifba@whitebg\colorlet{baCanvas}{baWhite}\fi

%% --- Typography: Blinker via fontspec ----------------------------------------
\defaultfontfeatures{Ligatures=TeX}
\setsansfont{Blinker}[
  Path = \ba@root fonts/, Extension = .ttf,
  UprightFont = *-Regular, BoldFont = *-Bold ]
\setmainfont{Blinker}[
  Path = \ba@root fonts/, Extension = .ttf,
  UprightFont = *-Regular, BoldFont = *-Bold ]
% Heavy display weight for headlines/titles, and a light weight for subtitles.
\newfontfamily\headlinefont{Blinker}[Path = \ba@root fonts/, Extension = .ttf, UprightFont = *-ExtraBold]
\newfontfamily\lightfont{Blinker}[Path = \ba@root fonts/, Extension = .ttf, UprightFont = *-Light]

%% --- Beamer colour theme -----------------------------------------------------
\setbeamercolor{background canvas}{bg=baCanvas}
\setbeamercolor{normal text}{fg=baBlack, bg=baCanvas}
\setbeamercolor{structure}{fg=baRed}
\setbeamercolor{alerted text}{fg=baRed}
\setbeamercolor{frametitle}{fg=baBlack}
\setbeamercolor{title}{fg=baBlack}
\setbeamercolor{subtitle}{fg=baBlack}
\setbeamercolor{itemize item}{fg=baBlack}
\setbeamercolor{itemize subitem}{fg=baBlack}
\setbeamercolor{itemize subsubitem}{fg=baBlack}
\setbeamercolor{block title}{bg=baBlack, fg=baWhite}
\setbeamercolor{block body}{bg=baBlack!6, fg=baBlack}
\setbeamercolor{block title alerted}{bg=baRed, fg=baWhite}
\setbeamercolor{block body alerted}{bg=baRed!10, fg=baBlack}
\setbeamercolor{fullbleed caption}{bg=baBlack, fg=baWhite}

%% --- Fonts in beamer ---------------------------------------------------------
\setbeamerfont{frametitle}{family=\headlinefont}
\setbeamerfont{title}{family=\headlinefont}
\setbeamerfont{headline}{size=\scriptsize}

%% --- Aspect-ratio-aware scaling ----------------------------------------------
% Beamer keeps font sizes physically constant across aspect ratios. On a
% narrower-than-16:9 canvas that makes the SAME points look oversized and, worse,
% the body column loses ~22% width while the page gains only ~7% height — so
% text-dense slides wrap to more lines than the extra height can hold and run off
% the bottom. We counter that AUTOMATICALLY, scaled smoothly with \paperwidth
% (so 5:4 / 16:10 / 3:2 are covered too — no hard cliff), via three layered
% levers — spacing first (no font shrink), then a heading scale, then a gentle
% body scale:
%   1. tighten list spacing on narrow formats
%   2. scale the bold display HEADINGS   down to ~0.90 at 4:3
%   3. scale the BODY size tree gently   down to ~0.92 at 4:3
% 16:9 and wider are the baseline: the narrowness s below is 0 there, so every
% lever is an exact no-op and 16:9 output is byte-for-byte unchanged. For the
% rare slide that is STILL too dense at 4:3, the escape hatch \narrowonly{<code>}
% (e.g. \narrowonly{\small}) runs <code> only on narrow formats.
%
% (Heading-only scaling on its own leaves dense 4:3 slides overflowing; measured
% on a real deck, spacing recovers only ~4pt of a ~29pt overflow, so the body
% scale carries most of the load. ~0.92 body + tightened lists clears it; 0.90
% headings keep their reviewed 4:3 look.)
%
% s = narrowness in [0,1]: 0 at the 16:9 width (455pt), 1 at the 4:3 width (364pt).
\pgfmathsetmacro\ba@s{max(0,min(1,(455-\paperwidth)/(455-364)))}
\pgfmathsetmacro\ba@hfactor{1-0.10*\ba@s}    % headings: 1.00 .. 0.90
\pgfmathsetmacro\ba@bfactor{1-0.08*\ba@s}    % body:     1.00 .. 0.92

% Lever 2 — headings. Uses \fontsize DIRECTLY (not the kernel size hook below),
% so headings get ONLY \ba@hfactor and are never double-scaled by the body lever.
% \ba@hsize{size}{baselineskip}; integer pt in, scaled by the decimal factor.
\newcommand\ba@hsize[2]{%
  \fontsize{\dimexpr\ba@hfactor\dimexpr#1pt\relax\relax}%
           {\dimexpr\ba@hfactor\dimexpr#2pt\relax\relax}\selectfont}

% Lever 3 — body. Scale the whole size tree by \ba@bfactor through \@setfontsize,
% the hook every \normalsize / \small / … funnels through, so all body sizes
% shrink in proportion. Direct \fontsize calls (our headings) bypass it, so the
% two levers never compound. At 16:9 \ba@bfactor=1 → exact no-op.
\let\ba@orig@setfontsize\@setfontsize
\renewcommand\@setfontsize[3]{%
  \ba@orig@setfontsize{#1}{\dimexpr\ba@bfactor\dimexpr#2pt\relax\relax}%
                         {\dimexpr\ba@bfactor\dimexpr#3pt\relax\relax}}

% Lever 1 — list spacing. Tighten level-1 itemize/enumerate only on narrow
% formats (16:9 keeps beamer's defaults untouched). \@listI is what \normalsize
% restores \@listi from, so set both for the tightening to persist.
\ifdim\paperwidth<450pt
  \def\@listi{\leftmargin\leftmargini \topsep 3\p@ \parsep \z@ \itemsep 2\p@}%
  \let\@listI\@listi
\fi

% Escape hatch: run <code> only on narrow (narrower-than-16:9) formats.
\newcommand\narrowonly[1]{\ifdim\paperwidth<450pt #1\fi}

%% --- Chrome ------------------------------------------------------------------
\setbeamertemplate{navigation symbols}{}
\setbeamersize{text margin left=20pt, text margin right=20pt}
\setbeamertemplate{blocks}[default]   % rectangular, sharp edges (matches the brand)

% Bullets: filled circle / open circle / filled square (per the brand master).
\setbeamertemplate{itemize item}{\small\raise0.4pt\hbox{\textbullet}}
\setbeamertemplate{itemize subitem}{\footnotesize\raise0.4pt\hbox{$\circ$}}
\setbeamertemplate{itemize subsubitem}{\footnotesize\raise0.4pt\hbox{\textbullet}}

% Top band: logomark (left) + running short title (centre) + frame number (right).
\setbeamertemplate{headline}{%
  \leavevmode%
  \vskip6pt%
  \hbox to \paperwidth{%
    \hskip14pt\relax
    \raisebox{-0.32\height}{\includegraphics[height=15pt]{ba-logomark}}%
    \hfill
    {\usebeamerfont{headline}\color{baBlack!75}\insertshorttitle}%
    \hfill
    {\usebeamerfont{headline}\color{baBlack!75}\insertframenumber}%
    \hskip14pt\relax
  }%
}

% No footline (the frame number lives in the headline).
\setbeamertemplate{footline}{}

% Frame title: heavy dark headline with a short red accent rule beneath.
\setbeamertemplate{frametitle}{%
  \vskip8pt%
  {\usebeamerfont{frametitle}\color{baBlack}\ba@hsize{19}{22}\insertframetitle}\par
  \vskip3pt%
  {\color{baRed}\rule{2.4em}{2pt}}\par
  \vskip4pt%
}

%% --- Title page --------------------------------------------------------------
\setbeamertemplate{title page}{%
  \vfill
  {\headlinefont\color{baBlack}\ba@hsize{36}{40}\inserttitle\par}%
  \vskip0.45em%
  {\color{baRed}\rule{2.6em}{3pt}\par}%
  \ifx\insertsubtitle\@empty\else
    \vskip0.9em{\lightfont\color{baBlack}\fontsize{18}{22}\selectfont\insertsubtitle\par}%
  \fi
  \vskip2.4em%
  {\color{baBlack}\insertauthor\par}%
  {\color{baBlack!70}\small\insertdate\par}%
  \vfill
  \hbox{\includegraphics[height=26pt]{ba-logo-horizontal}}%
}

%% --- Section divider (centred, like the brand master) ------------------------
\setbeamertemplate{section page}{%
  \centering\vfill
  {\headlinefont\color{baBlack}\ba@hsize{30}{34}\insertsectionhead\par}%
  \vskip0.4em{\color{baRed}\rule{2.4em}{2.5pt}\par}%
  \vfill
}
\AtBeginSection[]{%
  \begin{frame}[plain,noframenumbering]
    \sectionpage
  \end{frame}%
}

%% =============================================================================
%% Content macros — one macro per slide type, for consistency.
%% =============================================================================

%% \fullbleedslide[caption]{image}
%% A frame whose image fills the entire slide, edge to edge. The optional
%% caption is overlaid in a dark bar at the bottom (use it for a source URL).
% The image is scaled to the slide WIDTH and clipped to the page ("cover"), so
% it fills edge-to-edge without distortion. (Good for images up to ~16:9; a much
% wider panorama would letterbox top/bottom — scale by height instead if so.)
\newcommand{\fullbleedslide}[2][]{%
  {%
    \usebackgroundtemplate{%
      \begin{tikzpicture}[remember picture,overlay]
        \clip (current page.south west) rectangle (current page.north east);
        \node[anchor=center,inner sep=0] at (current page.center)
          {\includegraphics[width=\paperwidth]{#2}};
      \end{tikzpicture}%
    }%
    \begin{frame}[plain,noframenumbering]
      \notblank{#1}{%
        \begin{tikzpicture}[remember picture,overlay]
          \node[anchor=south, fill=baBlack, text=baWhite, align=center,
                minimum width=\paperwidth, inner xsep=8pt, inner ysep=7pt,
                font=\small] at (current page.south) {#1};
        \end{tikzpicture}%
      }{}%
    \end{frame}%
  }%
}

%% \fillerslide[subtitle]{headline}
%% A dark-background "filler" / topic-divider slide: black canvas, the light
%% logomark, a large white headline, a red accent rule, and an optional small
%% subtitle. Use it to separate topics.
\newcommand{\fillerslide}[2][]{%
  {%
    \setbeamercolor{background canvas}{bg=baBlack}%
    \begin{frame}[plain,noframenumbering]
      \centering\vfill
      \includegraphics[height=20pt]{ba-logomark-light}\par
      \vskip1.1em
      {\headlinefont\color{baWhite}\ba@hsize{30}{34} #2\par}%
      \vskip0.5em{\color{baRed}\rule{2.6em}{2.5pt}\par}%
      \notblank{#1}{\vskip0.7em{\lightfont\color{baWhite!85}\fontsize{15}{19}\selectfont #1\par}}{}%
      \vfill
    \end{frame}%
  }%
}

%% \comparisonslide{title}{left header}{left body}{right header}{right body}%
%%                 {note heading}{note body}
%% A two-column comparison: the left column carries the red accent, the right
%% column the dark accent, with an optional full-width callout underneath. Leave
%% the note heading and body empty ({}{}) to omit the callout.
\newcommand{\comparisonslide}[7]{%
  \begin{frame}{#1}
    \begin{columns}[T]
      \begin{column}{0.48\textwidth}
        \begingroup
          \setbeamercolor{block title}{bg=baRed,fg=baWhite}%
          \setbeamercolor{block body}{bg=baRed!8,fg=baBlack}%
          \begin{block}{#2}#3\end{block}
        \endgroup
      \end{column}
      \hfill
      \begin{column}{0.48\textwidth}
        \begingroup
          \setbeamercolor{block title}{bg=baBlack,fg=baWhite}%
          \setbeamercolor{block body}{bg=baBlack!6,fg=baBlack}%
          \begin{block}{#4}#5\end{block}
        \endgroup
      \end{column}
    \end{columns}
    \notblank{#7}{%
      \vfill
      \begin{alertblock}{#6}#7\end{alertblock}%
    }{}%
  \end{frame}%
}

%% \comparisontable{left header}{right header}{rows}
%% A booktabs comparison table for side-by-side technical comparisons: first
%% column = dimension labels, then a red-headed "left" column and a dark-headed
%% "right" column. Provide the body rows ("Dimension & left & right \\"). Use
%% inside a frame (add \centering to centre it).
\newcommand{\comparisontable}[3]{%
  {\small
   \setlength{\tabcolsep}{9pt}%
   \renewcommand{\arraystretch}{1.4}%
   \begin{tabular}{@{}lll@{}}
     \toprule
       & \textcolor{baRed}{\textbf{#1}} & \textbf{#2} \\
     \midrule
     #3
     \bottomrule
   \end{tabular}}%
}

%% \cornerimage[options]{image}      decorate the NEXT slide
%% \cornerimage*[options]{image}     decorate EVERY following slide (until reset)
%%
%% Floats a small image into a corner of a slide, OVER everything else — so it
%% works even on theme-generated slides (\comparisonslide, \fillerslide,
%% \fullbleedslide, plain frame) where you cannot inject frame content. Call it
%% IMMEDIATELY BEFORE the slide (or slide-macro) you want to decorate; the
%% unstarred form paints only the next shipped page, so it never bleeds onto the
%% slide after. The starred form persists across all following slides until
%% \clearcornerimage. Because the theme owns the layout, the default placement
%% clears the top logo/title band — the image never collides with the brand
%% furniture.
%%
%% Options (key=value). The optional argument may instead be a bare width for
%% backward compatibility, i.e. \cornerimage[3cm]{img} == \cornerimage[width=3cm]{img}:
%%   width=<len>      image width (default 0.13\paperwidth)
%%   height=<len>     cap the height too (keeps aspect ratio within the box)
%%   corner=<pos>     top-right (default), top-left, bottom-right, bottom-left
%%   trim=<l b r t>   crop the source by these amounts (implies clip)
%%   viewport=<llx lly urx ury>  show only this region of the source (implies clip)
%%   clip=true|false  clip to the trim/viewport box (auto-on when either is set)
%%   border=true|false  white matte frame around the image (default off)
%%   caption=<text>   small caption under the image, aligned to its outer edge
%%   hmargin=<len>    gap from the left/right page edge (default 14pt, brand inset)
%%   vmargin=<len>    gap from the bottom page edge, bottom corners (default 14pt)
%%   topclear=<len>   gap from the top page edge, top corners (default 26pt, sits
%%                    level with the frame title, just below the headline/page
%%                    number band; set ~6pt on plain/filler slides if desired)
\newsavebox\ba@ci@box
\newif\ifba@ci@persist
\newif\ifba@ci@clip
\newif\ifba@ci@border
\newlength\ba@ci@hmargin
\newlength\ba@ci@vmargin
\newlength\ba@ci@topclear
\def\ba@ci@cTR{top-right}\def\ba@ci@cTL{top-left}%
\def\ba@ci@cBR{bottom-right}\def\ba@ci@cBL{bottom-left}%

\define@key{ba@ci}{width}{\def\ba@ci@width{#1}}
\define@key{ba@ci}{height}{\def\ba@ci@height{#1}}
\define@key{ba@ci}{corner}{\def\ba@ci@corner{#1}}
\define@key{ba@ci}{trim}{\def\ba@ci@trim{#1}\ba@ci@cliptrue}
\define@key{ba@ci}{viewport}{\def\ba@ci@viewport{#1}\ba@ci@cliptrue}
\define@key{ba@ci}{clip}[true]{\csname ba@ci@clip#1\endcsname}
\define@key{ba@ci}{border}[true]{\csname ba@ci@border#1\endcsname}
\define@key{ba@ci}{caption}{\def\ba@ci@cap{#1}}
\define@key{ba@ci}{hmargin}{\setlength\ba@ci@hmargin{#1}}
\define@key{ba@ci}{vmargin}{\setlength\ba@ci@vmargin{#1}}
\define@key{ba@ci}{topclear}{\setlength\ba@ci@topclear{#1}}

\newcommand\cornerimage{\@ifstar
  {\ba@ci@persisttrue\ba@ci@grab}%
  {\ba@ci@persistfalse\ba@ci@grab}}
\newcommand\ba@ci@grab[2][]{%
  % reset to defaults so keys never leak between calls
  \def\ba@ci@width{0.13\paperwidth}\def\ba@ci@height{}\def\ba@ci@corner{top-right}%
  \def\ba@ci@trim{}\def\ba@ci@viewport{}\ba@ci@clipfalse
  \ba@ci@borderfalse\def\ba@ci@cap{}%
  \setlength\ba@ci@hmargin{14pt}\setlength\ba@ci@vmargin{14pt}%
  \setlength\ba@ci@topclear{26pt}%
  % parse optional arg: key=value list, or a bare width for backward compat
  \notblank{#1}{\in@{=}{#1}\ifin@\setkeys{ba@ci}{#1}\else\def\ba@ci@width{#1}\fi}{}%
  \ba@ci@emit{#2}%
}
% Build the image box (with optional crop / border / caption) and \put it.
\newcommand\ba@ci@emit[1]{%
  \edef\ba@ci@gopts{width=\ba@ci@width,keepaspectratio%
    \ifx\ba@ci@height\@empty\else,height=\ba@ci@height\fi%
    \ifx\ba@ci@trim\@empty\else,trim=\ba@ci@trim\fi%
    \ifx\ba@ci@viewport\@empty\else,viewport=\ba@ci@viewport\fi%
    \ifba@ci@clip,clip\fi}%
  \ifba@ci@persist
    \AddToShipoutPictureFG{\ba@ci@place{#1}}%
  \else
    \AddToShipoutPictureFG*{\ba@ci@place{#1}}%
  \fi}
\newcommand\ba@ci@place[1]{%
  % \expandafter so the option list reaches \includegraphics as real, comma-
  % separated keys (a bare macro token would be parsed as one undefined key).
  \sbox\ba@ci@box{%
    \ifba@ci@border
      \setlength{\fboxsep}{2.5pt}\setlength{\fboxrule}{0.8pt}%
      \fcolorbox{baWhite}{baWhite}%
        {\expandafter\includegraphics\expandafter[\ba@ci@gopts]{#1}}%
    \else
      \expandafter\includegraphics\expandafter[\ba@ci@gopts]{#1}%
    \fi}%
  % caption: stack it under the image, aligned to the image's outer edge
  \notblank{\ba@ci@cap}{%
    \edef\ba@ci@just{\ifx\ba@ci@corner\ba@ci@cTL\noexpand\raggedright\else
      \ifx\ba@ci@corner\ba@ci@cBL\noexpand\raggedright\else\noexpand\raggedleft\fi\fi}%
    \sbox\ba@ci@box{%
      \begin{minipage}{\wd\ba@ci@box}%
        \usebox\ba@ci@box\par\vskip2pt
        {\scriptsize\color{baBlack!70}\ba@ci@just\ba@ci@cap\par}%
      \end{minipage}}%
  }{}%
  % Normalise the box to zero depth so its reference point is its bottom edge:
  % the corner maths can then anchor box edges directly to the page edges.
  \sbox\ba@ci@box{\raisebox{\dp\ba@ci@box}{\usebox\ba@ci@box}}%
  % The shipout-foreground picture has its origin at the page's LOWER-LEFT corner.
  % x: left corners hug hmargin; right corners hug the right edge.
  \edef\ba@ci@x{\ifx\ba@ci@corner\ba@ci@cTL\the\ba@ci@hmargin\else
    \ifx\ba@ci@corner\ba@ci@cBL\the\ba@ci@hmargin\else
    \the\dimexpr\paperwidth-\ba@ci@hmargin-\wd\ba@ci@box\relax\fi\fi}%
  % y: bottom corners sit vmargin above the bottom edge; top corners drop topclear
  % below the top edge (box height now includes the former depth).
  \edef\ba@ci@y{\ifx\ba@ci@corner\ba@ci@cBR\the\ba@ci@vmargin\else
    \ifx\ba@ci@corner\ba@ci@cBL\the\ba@ci@vmargin\else
    \the\dimexpr\paperheight-\ba@ci@topclear-\ht\ba@ci@box\relax\fi\fi}%
  \put(\LenToUnit{\ba@ci@x},\LenToUnit{\ba@ci@y}){\usebox\ba@ci@box}%
}
% Stop a persistent \cornerimage* from decorating further slides.
\newcommand\clearcornerimage{\ClearShipoutPictureFG}

\endinput
